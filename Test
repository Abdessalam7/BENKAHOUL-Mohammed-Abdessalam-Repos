airflow connections get ssh_conn -o json | python3 -c "
import json, sys
data = json.load(sys.stdin)
extra = data[0]['extra_dejson']
# extra_dejson est déjà un dict, pas besoin de json.loads()
if isinstance(extra, str):
    extra = json.loads(extra)
with open('/tmp/vsi_key', 'w') as f:
    f.write(extra['private_key'])
print('OK')
"
