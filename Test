python3 << 'EOF'
import paramiko

key = paramiko.RSAKey.from_private_key_file('/tmp/vsi_key')

client = paramiko.SSHClient()
client.set_missing_host_key_policy(paramiko.AutoAddPolicy())

print("Connexion en cours...")
client.connect(
    hostname='10.228.207.21',
    port=22,
    username='datahub_dz',
    pkey=key,
    timeout=10
)

print("Connecté ! Exécution de la commande...")
stdin, stdout, stderr = client.exec_command('echo "Connexion VSI OK"')
print("STDOUT:", stdout.read().decode())
print("STDERR:", stderr.read().decode())

client.close()
print("Done.")
EOF
