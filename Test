python3 << 'EOF'
import paramiko
import io

with open('/tmp/vsi_key', 'r') as f:
    key_content = f.read()

# API correcte pour 3.x
key = paramiko.pkey.PKey.from_private_key(io.StringIO(key_content))

client = paramiko.SSHClient()
client.set_missing_host_key_policy(paramiko.AutoAddPolicy())

print("Connexion en cours...")
client.connect(
    hostname='10.228.207.21',
    port=22,
    username='datahub_dz',
    pkey=key,
    timeout=10
)

print("Connecté !")
stdin, stdout, stderr = client.exec_command('echo "Connexion VSI OK"')
print("STDOUT:", stdout.read().decode())
print("STDERR:", stderr.read().decode())

client.close()
print("Done.")
EOF
