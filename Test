script:
  - echo "DEBUG: checking VAULT_ID_TOKEN 
    - echo "DEBUG -> decoding VAULT_ID_TOKEN payload"
  - |
      python - <<'PY'
      import os,base64,json
      t=os.environ["VAULT_ID_TOKEN"]
      p=t.split(".")[1]
      p += "=" * (-len(p) % 4)
      payload=json.loads(base64.urlsafe_b64decode(p))
      # on n'affiche que les champs utiles (et non sensibles)
      keys = ["iss","aud","sub","project_path","project_id","namespace_path","ref","ref_type","ref_protected"]
      out = {k: payload.get(k) for k in keys if k in payload}
      print(json.dumps(out, indent=2))
      PY
  - vault write -namespace="ap101731" -field=token \
      auth/${VAULT_AUTH}/login \
      role=pysmoke-helm-ci \
      jwt="${VAULT_ID_TOKEN}" \
      token_ttl=1m > ~/.vault-token
