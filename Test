# 1. Extraire la clé privée
python3 -c "
import json
with open('/tmp/conn.json') as f:
    data = json.load(f)
extra = data[0]['extra_dejson']
with open('/tmp/vsi_key', 'w') as f:
    f.write(extra['private_key'])
print('OK')
"

# 2. Permissions
chmod 600 /tmp/vsi_key

# 3. Vérifier que la clé est bien écrite
head -2 /tmp/vsi_key

# 4. Tester SSH
ssh -vvv \
  -i /tmp/vsi_key \
  -o StrictHostKeyChecking=no \
  -p 22 \
  datahub_dz@10.228.207.21 \
  "echo 'Connexion VSI OK'"
